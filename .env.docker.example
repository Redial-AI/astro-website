# Reverse proxy
PROXY_PORT=80

# Public base URL used by Strapi and Astro-generated media links
# Example production value: https://your-domain.com
PUBLIC_URL=http://localhost
PUBLIC_STRAPI_URL=http://localhost

# Frontend URL for Strapi preview links / CSP frame-src
CLIENT_URL=http://localhost

# Optional API token if content is private
STRAPI_API_TOKEN=
