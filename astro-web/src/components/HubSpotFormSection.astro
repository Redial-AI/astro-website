---
import HubSpotForm from "./HubSpotForm.astro";

interface Props {
  hubspotFormId: string;
  title?: string;
  subtitle?: string;
  region?: string;
}

const {
  hubspotFormId,
  title = "Get in Touch",
  subtitle,
  region = "na1",
} = Astro.props;

const HUBSPOT_PORTAL_ID =
  process.env.HUBSPOT_PORTAL_ID || import.meta.env.HUBSPOT_PORTAL_ID || "";
---

{HUBSPOT_PORTAL_ID && hubspotFormId && (
  <section class="hubspot-section">
    <div class="container">
      <HubSpotForm
        portalId={HUBSPOT_PORTAL_ID}
        formId={hubspotFormId}
        region={region}
        title={title}
        subtitle={subtitle}
      />
    </div>
  </section>
)}

<style>
  .hubspot-section {
    padding: 4rem 0;
  }
</style>
