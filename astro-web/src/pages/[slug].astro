---
import Base from "../layouts/Base.astro";
import PageDynamicZone from "../components/PageDynamicZone.astro";
import { getLandingPageData, getPageBySlug } from "../lib/strapi";
import "../styles/globals.css";

export const prerender = false;

const { slug } = Astro.params;
const isPreview = Astro.cookies.has("astro-preview");

const [landingData, page] = await Promise.all([
  getLandingPageData(isPreview),
  getPageBySlug(slug as string, isPreview),
]);

if (!page) {
  return Astro.redirect("/404");
}
---

<Base title={page.title} description={landingData.metaDescription}>
  <header class="site-header">
    <div class="container nav-shell">
      <a class="brand" href="/">
        {landingData.settings.logo ? (
          <img
            src={landingData.settings.logo}
            alt={landingData.settings.siteName}
            width="140"
            height="32"
            class="brand-logo"
          />
        ) : (
          <span class="brand-mark">{landingData.settings.siteName}</span>
        )}
      </a>

      <nav aria-label="Main navigation" class="main-nav">
        {landingData.settings.navLinks.map((link) => (
          <a
            href={link.href}
            target={link.openInNewTab ? "_blank" : undefined}
            rel={link.openInNewTab ? "noreferrer" : undefined}
          >
            {link.label}
          </a>
        ))}
        <span class="nav-separator"></span>
        <a href="/blog">Blog</a>
      </nav>

      <a class="button button-primary button-compact" href={landingData.settings.primaryActionHref}>
        {landingData.settings.primaryActionLabel}
      </a>
    </div>
  </header>

  <main id="main-content">
    <PageDynamicZone blocks={page.blocks} settings={landingData.settings} />
  </main>

  <footer class="site-footer">
    <div class="container footer-shell">
      <p>{landingData.settings.footerCopy}</p>
      {landingData.footerNote && <p>{landingData.footerNote}</p>}
    </div>
  </footer>
</Base>

