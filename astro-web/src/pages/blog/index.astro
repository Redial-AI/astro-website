---
import Base from "../../layouts/Base.astro";
import HubSpotForm from "../../components/HubSpotForm.astro";
import { getLandingPageData, getBlogPosts } from "../../lib/strapi";
import "../../styles/globals.css";

export const prerender = false;

const isPreview = Astro.cookies.has("astro-preview");
const [data, posts] = await Promise.all([
  getLandingPageData(isPreview),
  getBlogPosts(isPreview)
]);

const HUBSPOT_PORTAL_ID =
  process.env.HUBSPOT_PORTAL_ID || import.meta.env.HUBSPOT_PORTAL_ID || "";

---

<Base title="Blog | Redial BPO" description="Read the latest blog posts from Redial BPO.">
  <header class="site-header">
    <div class="container nav-shell">
      <a class="brand" href="/">
        {data.settings.logo ? (
          <img
            src={data.settings.logo}
            alt={data.settings.siteName}
            width="140"
            height="32"
            class="brand-logo"
          />
        ) : (
          <span class="brand-mark">{data.settings.siteName}</span>
        )}
      </a>

      <nav aria-label="Main navigation" class="main-nav">
        {data.settings.navLinks.map((link) => (
          <a
            href={link.href}
            target={link.openInNewTab ? "_blank" : undefined}
            rel={link.openInNewTab ? "noreferrer" : undefined}
          >
            {link.label}
          </a>
        ))}
        <span class="nav-separator"></span>
        <a href="/blog">Blog</a>
      </nav>

      <a class="button button-primary button-compact" href={data.settings.primaryActionHref}>
        {data.settings.primaryActionLabel}
      </a>
    </div>
  </header>

  <main id="main-content" class="container" style="padding: 4rem 0; min-height: 60vh;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
      <h1 style="font-family: var(--font-display); font-size: 2.5rem; margin: 0;">Blog</h1>
      <a href="/blog/create" class="button button-primary">+ New Post</a>
    </div>

    {posts.length === 0 ? (
      <div class="card" style="text-align: center; padding: 4rem 2rem;">
        <h3 style="margin-bottom: 1rem; color: var(--ink-700);">No posts yet.</h3>
        <p>Be the first to publish a blog post!</p>
      </div>
    ) : (
      <div class="card-grid card-grid-2">
        {posts.map((post) => (
          <a href={`/blog/${post.slug || post.documentId}`} class="card" style="display: flex; flex-direction: column; height: 100%; transition: transform 0.2s ease, box-shadow 0.2s ease;">
            {post.images && post.images.length > 0 && (
               <img 
                 src={post.images[0]} 
                 alt={post.title} 
                 style="width: 100%; height: 200px; object-fit: cover; border-radius: var(--radius-sm); margin-bottom: 1rem;" 
               />
            )}
            <h3 style="margin-bottom: 0.5rem; color: var(--ink-950);">{post.title}</h3>
            {post.description && <p style="margin-bottom: 1rem; flex-grow: 1; color: var(--ink-800);">{post.description}</p>}
            
            <div style="margin-top: auto; padding-top: 1rem; font-size: 0.85rem; color: var(--ink-700); border-top: 1px solid rgba(0,0,0,0.05); display: flex; justify-content: space-between; align-items: center;">
              {post.author ? <span>Published by <strong>{post.author}</strong></span> : <span>Redial BPO</span>}
              <span>{new Date(post.createdAt || Date.now()).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
            </div>
          </a>
        ))}
      </div>
    )}

    {HUBSPOT_PORTAL_ID && data.settings.blogForm?.formId && (
      <div style="margin-top: 4rem;">
        <HubSpotForm
          portalId={HUBSPOT_PORTAL_ID}
          formId={data.settings.blogForm.formId}
          region={data.settings.blogForm.region}
          title="Stay in the Loop"
          subtitle="Subscribe to get the latest insights on BPO, outsourcing, and customer experience."
        />
      </div>
    )}
  </main>

  <footer class="site-footer">
    <div class="container footer-shell">
      <p>{data.settings.footerCopy}</p>
      {data.footerNote && <p>{data.footerNote}</p>}
    </div>
  </footer>
</Base>
